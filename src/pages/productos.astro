---
import Header from "@/sections/Header.astro";
import { productos } from "@/data/data";
/* import LayoutProductos from "@/layouts/LayoutProductos.astro"; */
import Layout from "@/layouts/Layout.astro";
import CatalogoProducCard from "@/components/catalogo/CatalogoProducCard.astro";
---

<Layout>
  <section class="pt-24 bg-gradient-to-br from-crema to-30% to-more-light">
    <div id="container" class="flex gap-4 max-w-6xl mx-auto p-2 pb-18">
      <aside id="filters" class="w-1/4 md:w-72 flex-shrink-0">
        <div
          class="sticky top-6 bg-[#FFFDF9] border border-pink-100 rounded-3xl p-6 shadow-sm"
        >
          <h2
            class="text-2xl font-bold text-pink-900 mb-6 flex items-center gap-2"
          >
            <span>Filtros</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
              ></path>
            </svg>
          </h2>

          <div class="mb-8">
            <label class="block text-sm font-semibold text-pink-800 mb-2"
              >Buscar producto</label
            >
            <input
              type="text"
              placeholder="Escribe algo lindo..."
              class="w-full px-4 py-2 rounded-xl border border-pink-100 focus:ring-2 focus:ring-pink-200 focus:border-pink-300 outline-none text-sm transition-all"
            />
          </div>

          <div class="mb-8">
            <span
              class="block text-sm font-semibold text-pink-800 mb-3 text-uppercase tracking-wider"
              >Categorías</span
            >
            <select
              name="categoriasfilter"
              id="categoriasfilter"
              class="w-full text-pink-900 border border-pink-100 rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-pink-200 focus:border-pink-300 outline-none transition-all"
            >
              <option value="todos">Todos</option>
              <option value="amigurumis">Amigurumis</option>
              <option value="bolsos">Bolsos</option>
              <option value="decoracion">Accesorios</option>
            </select>
          </div>

          <div class="mb-8">
            <span class="block text-sm font-semibold text-pink-800 mb-3"
              >Precio máximo</span
            >
            <input
              type="range"
              class="w-full h-2 bg-pink-100 rounded-lg appearance-none cursor-pointer accent-pink-500"
            />
            <div
              class="flex justify-between text-xs text-pink-400 mt-2 font-medium"
            >
              <span>$0</span>
              <span>$100</span>
            </div>
          </div>

          <div class="mb-8">
            <span class="block text-sm font-semibold text-pink-800 mb-3"
              >Orden Alfabético</span
            >
            <div class="flex p-1 bg-pink-50 rounded-xl">
              <button
                type="radio"
                class="flex-1 py-2 text-xs font-bold bg-white text-pink-600 rounded-lg shadow-sm"
                >A - Z
              </button>
              <button
                class="flex-1 py-2 text-xs font-bold text-pink-400 hover:text-pink-600 transition-colors"
                >Z - A</button
              >
            </div>
          </div>

          <!-- <div class="mb-8 flex items-center justify-between">
            <span class="text-sm font-semibold text-pink-800"
              >Solo en stock</span
            >
            <button
              class="w-10 h-5 bg-pink-200 rounded-full relative shadow-inner"
            >
              <div class="absolute right-1 top-1 w-3 h-3 bg-white rounded-full">
              </div>
            </button>
          </div> -->

          <div class="mb-8">
            <span class="block text-sm font-semibold text-pink-800 mb-3"
              >Popular Tags</span
            >
            <div class="flex flex-wrap gap-2">
              <span
                class="px-3 py-1 bg-pink-50 text-pink-600 text-xs rounded-full border border-pink-100 hover:bg-pink-100 cursor-pointer"
                >#Kawaii</span
              >
              <span
                class="px-3 py-1 bg-pink-50 text-pink-600 text-xs rounded-full border border-pink-100 hover:bg-pink-100 cursor-pointer"
                >#Handmade</span
              >
              <span
                class="px-3 py-1 bg-pink-50 text-pink-600 text-xs rounded-full border border-pink-100 hover:bg-pink-100 cursor-pointer"
                >#Pastel</span
              >
            </div>
          </div>

          <!-- <div class="mb-4">
            <span class="block text-sm font-semibold text-pink-800 mb-3"
              >Valoración</span
            >
            <div class="space-y-1">
              <button
                class="flex items-center text-yellow-400 text-sm hover:translate-x-1 transition-transform"
              >
                ★★★★<span class="text-gray-300">★</span>
                <span class="ml-2 text-gray-500 text-xs">(o más)</span>
              </button>
            </div>
          </div> -->

          <button
            class="w-full cursor-pointer mt-4 py-3 bg-pink-700 text-white font-bold rounded-2xl shadow-lg shadow-pink-100 hover:bg-pink-600 transition-all active:scale-95"
          >
            Limpiar Filtros
          </button>
        </div>
      </aside>

      <section class="w-3/4 grid md:grid-cols-3 gap-4">
        <h2
          class="text-2xl md:text-4xl font-caveat text-nowrap md:col-span-3 text-pink-900 text-end"
        >
          ¡Productos disponibles!
        </h2>
        <CatalogoProducCard informacion={productos} />
        <CatalogoProducCard informacion={productos} />
        <CatalogoProducCard informacion={productos} />
        <CatalogoProducCard informacion={productos} />
        <CatalogoProducCard informacion={productos} />
      </section>
    </div>
  </section>
</Layout>
