---
import Header from "@/sections/Header.astro";
import { productos } from "@/data/data";
/* import LayoutProductos from "@/layouts/LayoutProductos.astro"; */
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <section
    class="pt-24 h-screen bg-gradient-to-br from-crema to-30% to-more-light"
  >
    <div id="container" class="flex gap-4 max-w-6xl mx-auto p-2">
      <section id="filters" class="w-1/4 h-screen bg-crema/70 p-4 rounded-lg">
        filtros
      </section>
      <section class="w-3/4">
        <h4>Productos disponibles a la venta</h4>
        <article
          class="max-w-sm bg-[#FFFDF9] rounded-3xl overflow-hidden border border-pink-100 shadow-sm hover:shadow-md transition-shadow duration-300 font-sans"
        >
          <div class="relative h-64 w-full">
            <img
              src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?q=80&w=1000&auto=format&fit=crop"
              alt="Nombre del Producto"
              class="w-full h-full object-cover"
            />
            <div
              class="absolute top-4 right-4 flex items-center justify-center w-12 h-12 bg-pink-200 text-pink-700 rounded-full border-2 border-white shadow-sm font-bold text-sm tracking-tighter"
              title="Cantidad disponible"
            >
              12
            </div>
          </div>

          <div class="p-6">
            <div class="flex justify-between items-start mb-2">
              <h2 class="text-xl font-semibold text-pink-900 leading-tight">
                Producto Artesanal
              </h2>
              <span
                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700 border border-emerald-200"
              >
                Disponible
              </span>
            </div>

            <p class="text-2xl font-bold text-pink-600 mb-3">$24.00</p>

            <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-3">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do
              eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut
              enim ad minim veniam, quis nostrud exercitation ullamco laboris
              nisi ut aliquip ex ea commodo consequat.
            </p>

            <button
              class="w-full py-3 px-4 bg-pink-100 hover:bg-pink-200 text-pink-700 font-semibold rounded-2xl transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-pink-300"
            >
              Añadir al carrito
            </button>
          </div>
        </article>
      </section>
    </div>
  </section>
</Layout>
