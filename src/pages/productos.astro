---
import Header from "@/sections/Header.astro";
import { productos } from "@/data/data";
/* import LayoutProductos from "@/layouts/LayoutProductos.astro"; */
import Layout from "@/layouts/Layout.astro";
import CatalogoProducCard from "@/components/catalogo/CatalogoProducCard.astro";
---

<Layout>
  <section class="pt-24 bg-gradient-to-br from-crema to-30% to-more-light">
    <div id="container" class="flex gap-4 max-w-6xl mx-auto p-2 pb-18">
      <aside id="filters" class="w-1/4 md:w-72 flex-shrink-0">
        <div
          class="sticky top-6 bg-[#FFFDF9] border border-pink-100 rounded-3xl p-6 shadow-sm"
        >
          <h2
            class="text-2xl font-bold text-pink-900 mb-6 flex items-center gap-2"
          >
            <span>Filtros</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
              ></path>
            </svg>
          </h2>

          <div class="mb-8">
            <label class="block text-sm font-semibold text-pink-800 mb-2"
              >Buscar producto</label
            >
            <input
              type="text"
              id="searchInput"
              placeholder="Escribe algo lindo..."
              class="w-full px-4 py-2 rounded-xl border border-pink-100 focus:ring-2 focus:ring-pink-200 focus:border-pink-300 outline-none text-sm transition-all"
            />
          </div>

          <div class="mb-8">
            <span
              class="block text-sm font-semibold text-pink-800 mb-3 text-uppercase tracking-wider"
              >Categorías</span
            >
            <select
              name="categoriasfilter"
              id="categoriasfilter"
              class="w-full text-pink-900 border border-pink-100 rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-pink-200 focus:border-pink-300 outline-none transition-all"
            >
              <option value="todos">Todos</option>
              <option value="amigurumis">Amigurumis</option>
              <option value="bolsos">Bolsos</option>
              <option value="decoracion">Accesorios</option>
            </select>
          </div>

          <div class="mb-8">
            <span class="block text-sm font-semibold text-pink-800 mb-3"
              >Precio máximo</span
            >
            <input
              type="range"
              class="w-full h-2 bg-pink-100 rounded-lg appearance-none cursor-pointer accent-pink-500"
            />
            <div
              class="flex justify-between text-xs text-pink-400 mt-2 font-medium"
            >
              <span>$0</span>
              <span>$100</span>
            </div>
          </div>

          <div class="mb-8">
            <span class="block text-sm font-semibold text-pink-800 mb-3"
              >Orden Alfabético</span
            >
            <div class="flex p-1 bg-pink-50 rounded-xl">
              <button
                type="radio"
                class="flex-1 py-2 text-xs font-bold bg-white text-pink-600 rounded-lg shadow-sm"
                >A - Z
              </button>
              <button
                class="flex-1 py-2 text-xs font-bold text-pink-400 hover:text-pink-600 transition-colors"
                >Z - A</button
              >
            </div>
          </div>

          <!-- <div class="mb-8 flex items-center justify-between">
            <span class="text-sm font-semibold text-pink-800"
              >Solo en stock</span
            >
            <button
              class="w-10 h-5 bg-pink-200 rounded-full relative shadow-inner"
            >
              <div class="absolute right-1 top-1 w-3 h-3 bg-white rounded-full">
              </div>
            </button>
          </div> -->

          <div class="mb-8">
            <span class="block text-sm font-semibold text-pink-800 mb-3"
              >Popular Tags</span
            >
            <div class="flex flex-wrap gap-2">
              <span
                class="px-3 py-1 bg-pink-50 text-pink-600 text-xs rounded-full border border-pink-100 hover:bg-pink-100 cursor-pointer"
                >#Kawaii</span
              >
              <span
                class="px-3 py-1 bg-pink-50 text-pink-600 text-xs rounded-full border border-pink-100 hover:bg-pink-100 cursor-pointer"
                >#Handmade</span
              >
              <span
                class="px-3 py-1 bg-pink-50 text-pink-600 text-xs rounded-full border border-pink-100 hover:bg-pink-100 cursor-pointer"
                >#Pastel</span
              >
            </div>
          </div>

          <!-- <div class="mb-4">
            <span class="block text-sm font-semibold text-pink-800 mb-3"
              >Valoración</span
            >
            <div class="space-y-1">
              <button
                class="flex items-center text-yellow-400 text-sm hover:translate-x-1 transition-transform"
              >
                ★★★★<span class="text-gray-300">★</span>
                <span class="ml-2 text-gray-500 text-xs">(o más)</span>
              </button>
            </div>
          </div> -->

          <button
            class="w-full cursor-pointer mt-4 py-3 bg-pink-700 text-white font-bold rounded-2xl shadow-lg shadow-pink-100 hover:bg-pink-600 transition-all active:scale-95"
          >
            Limpiar Filtros
          </button>
        </div>
      </aside>

      <section class="w-3/4 grid grid-cols-1 md:grid-cols-3 gap-4">
        <h2
          class="text-2xl md:text-4xl font-caveat text-nowrap md:col-span-3 text-pink-900 text-end"
        >
          ¡Productos disponibles!
        </h2>
        <div id="productList" class="md:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-4">
          {productos.map((producto) => (
            <div data-nombre={producto.nombre.toLowerCase()} data-index>
              <CatalogoProducCard informacion={producto} />
            </div>
          ))}
        </div>
        <div id="pagination" class="md:col-span-3 flex justify-center gap-2 mt-4"></div>
        <p id="noResults" class="hidden md:col-span-3 text-center text-pink-400 py-8">
          No se encontraron productos :(
        </p>
      </section>

      <script define:vars={{ productos }}>
        const searchInput = document.getElementById('searchInput');
        const productList = document.getElementById('productList');
        const pagination = document.getElementById('pagination');
        const noResults = document.getElementById('noResults');
        const ITEMS_PER_PAGE = 9;
        let currentPage = 1;

        function renderProducts(page = 1) {
          const query = searchInput.value.toLowerCase().trim();
          const items = productList.querySelectorAll('[data-index]');
          const filtered = [];

          items.forEach(item => {
            const nombre = item.getAttribute('data-nombre') || '';
            if (!query || nombre.includes(query)) {
              item.style.display = '';
              filtered.push(item);
            } else {
              item.style.display = 'none';
            }
          });

          if (filtered.length === 0 && query) {
            noResults.classList.remove('hidden');
          } else {
            noResults.classList.add('hidden');
          }

          filtered.forEach((item, i) => {
            item.style.display = (i >= (page - 1) * ITEMS_PER_PAGE && i < page * ITEMS_PER_PAGE) ? '' : 'none';
          });

          const totalPages = Math.ceil(filtered.length / ITEMS_PER_PAGE);
          
          pagination.innerHTML = '';
          if (totalPages > 1) {
            const prev = document.createElement('button');
            prev.textContent = '←';
            prev.className = 'px-3 py-1 rounded-lg ' + (page === 1 ? 'bg-pink-100 text-pink-300 cursor-not-allowed' : 'bg-pink-600 text-white hover:bg-pink-500');
            prev.disabled = page === 1;
            prev.onclick = () => { if (page > 1) renderProducts(page - 1); };
            pagination.appendChild(prev);

            for (let i = 1; i <= totalPages; i++) {
              const btn = document.createElement('button');
              btn.textContent = i;
              btn.className = 'px-3 py-1 rounded-lg ' + (i === page ? 'bg-pink-600 text-white' : 'bg-pink-100 text-pink-600 hover:bg-pink-200');
              btn.onclick = () => renderProducts(i);
              pagination.appendChild(btn);
            }

            const next = document.createElement('button');
            next.textContent = '→';
            next.className = 'px-3 py-1 rounded-lg ' + (page === totalPages ? 'bg-pink-100 text-pink-300 cursor-not-allowed' : 'bg-pink-600 text-white hover:bg-pink-500');
            next.disabled = page === totalPages;
            next.onclick = () => { if (page < totalPages) renderProducts(page + 1); };
            pagination.appendChild(next);
          }
        }

        searchInput.addEventListener('input', () => { currentPage = 1; renderProducts(1); });
        renderProducts();
      </script>
    </div>
  </section>
</Layout>
